PORT=5001
NODE_ENV=production
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/fondation_bac
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
FRONTEND_URL=https://your-frontend-project.vercel.app
# Pour plusieurs URLs autorisées, utilisez FRONTEND_URLS au lieu de FRONTEND_URL
# FRONTEND_URLS=https://your-frontend-project.vercel.app,https://www.your-domain.com
COOKIE_SAME_SITE=none
# COOKIE_DOMAIN=.your-domain.com
